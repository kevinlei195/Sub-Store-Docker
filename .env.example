# ============================================================
# Sub-Store 环境变量配置
# ============================================================
# 复制此文件为 .env 并修改配置
# cp .env.example .env
# ============================================================

# ============================================================
# 基础配置 (必填)
# ============================================================
# 后端路径密钥，用于认证和访问 (必须以 / 开头)
SUB_STORE_FRONTEND_BACKEND_PATH=/your-secret

# ============================================================
# 端口配置
# ============================================================
# 前端端口
SUB_STORE_FRONTEND_PORT=3000

# 后端 API 端口
SUB_STORE_BACKEND_API_PORT=3001

# 前端静态文件路径 (Docker 镜像内置，无需修改)
SUB_STORE_FRONTEND_PATH=/app/frontend/dist

# ============================================================
# 定时任务配置 (可选)
# ============================================================
# 定时同步订阅 (Cron 表达式)
# 每 6 小时执行一次
# SUB_STORE_BACKEND_SYNC_CRON=0 */6 * * *

# 定时刷新远程订阅 (Cron 表达式)
# 每 12 小时执行一次
# SUB_STORE_BACKEND_REFRESH_CRON=0 */12 * * *

# ============================================================
# GitHub Gist 备份 (可选)
# ============================================================
# GitHub 用户名
# GITHUB_USERNAME=

# GitHub Token (需要 Gist 权限)
# 生成方式: GitHub -> Settings -> Developer settings -> Personal access tokens -> Tokens (classic)
# 权限: gist
# GITHUB_TOKEN=

# 定时上传备份到 Gist (Cron 表达式)
# 每周六 23:55 执行
# SUB_STORE_BACKEND_UPLOAD_CRON=55 23 * * 6

# 定时从 Gist 下载恢复 (Cron 表达式)
# 每周日 02:30 执行
# SUB_STORE_BACKEND_DOWNLOAD_CRON=30 2 * * 0

# ============================================================
# 前端反向代理配置 (可选)
# ============================================================
# 前端请求后端 API 时使用的基础 URL
# 用于 Nginx/Caddy 反向代理场景
# 示例: http://localhost:3001 或 https://sub-store.example.com
# SUB_STORE_FRONTEND_BACKEND_URL=
